# Скопируй в `.env` для локальной разработки. Секреты в Git не коммитить.

# --- Обязательно для приложения ---
# Supabase: пул (transaction, порт 6543) для рантайма; direct — для миграций Prisma (см. Connect в дашборде).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=public"
# Публичный URL сайта без завершающего слэша (ссылки в Telegram, напоминания)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Supabase (обязательно на Vercel в production: фото и сметы) ---
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_PHOTOS_BUCKET="item-photos"
SUPABASE_STORAGE_ESTIMATES_BUCKET="estimates"
# Модуль «Проекты»: файлы карточки (папки). Создать bucket в Supabase с тем же именем.
SUPABASE_STORAGE_PROJECTS_BUCKET="project-files"

# --- Telegram (опционально) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_NOTIFICATION_CHAT_ID=
# TELEGRAM_NOTIFICATION_TOPIC_ID=
# TELEGRAM_PROJECTS_TOPIC_ID=
# TELEGRAM_SEND_TIMEOUT_MS=20000
# TELEGRAM_HTTPS_PROXY=

# --- Cron (опционально; без секрета эндпоинты вернут 500) ---
# Для Vercel Cron: добавить CRON_SECRET в Project Settings -> Environment Variables.
# Vercel сам пришлёт Authorization: Bearer <CRON_SECRET> на cron-path.
# INVENTORY_AUDIT_CRON_TOKEN можно оставить для ручных POST-вызовов/внешнего cron.
# CRON_SECRET=
# REMINDERS_CRON_TOKEN=
# INVENTORY_AUDIT_CRON_TOKEN=

# --- Сид: логины/пароли тестовых пользователей (опционально) ---
# SEED_ADMIN_LOGIN=admin
# SEED_ADMIN_PASSWORD=admin12345
# SEED_GREENWICH_LOGIN=greenwich
# SEED_GREENWICH_PASSWORD=greenwich12345
