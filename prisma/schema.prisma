generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  GREENWICH
  WOWSTORG
}

enum ItemType {
  ASSET
  BULK
  CONSUMABLE
}

enum OrderSource {
  GREENWICH_INTERNAL
  WOWSTORG_EXTERNAL
}

enum OrderStatus {
  SUBMITTED
  ESTIMATE_SENT
  CHANGES_REQUESTED
  APPROVED_BY_GREENWICH
  PICKING
  ISSUED
  RETURN_DECLARED
  CLOSED
  CANCELLED
}

enum OrderDiscountType {
  NONE
  PERCENT
  AMOUNT
}

enum Condition {
  OK
  NEEDS_REPAIR
  BROKEN
  MISSING
}

enum ReturnPhase {
  DECLARED
  CHECKED_IN
}

enum LossStatus {
  OPEN
  FOUND
  WRITTEN_OFF
}

enum IncidentStatus {
  OPEN
  CLOSED
}

enum AchievementCode {
  PERFECT_ORDERS
  TOWER_SCORE
  ORDER_VOLUME
  BIGGEST_CHECK
  CLOSED_ORDERS
  NO_CANCEL_STREAK
}

enum AchievementLevel {
  NONE
  BRONZE
  SILVER
  GOLD
}

enum InAppNotificationType {
  ACHIEVEMENT_UNLOCK
  ORDER_STATUS_CHANGED
  ORDER_UPDATED
  ORDER_DISCOUNT
  PROJECT_UPDATED
  SYSTEM
}

enum ProjectStatus {
  LEAD
  BRIEFING
  INTERNAL_PREP
  PROPOSAL_SENT
  PROPOSAL_REVISION
  CONTRACT_PREP
  CONTRACT_SENT
  CONTRACT_SIGNED
  PREPRODUCTION
  AWAITING_CLIENT_INPUT
  AWAITING_VENDOR
  READY_TO_RUN
  LIVE
  WRAP_UP
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum ProjectBall {
  CLIENT
  WOWSTORG
  VENDOR
  VENUE
  NONE
}

enum ProjectContactCategory {
  DECISION_MAKER
  CONTRACTOR
  VENUE
  OTHER
}

enum ProjectActivityKind {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_ARCHIVED
  ORDER_LINKED
  ORDER_CANCELLED
  PROJECT_DRAFT_ORDER_UPDATED
  PROJECT_DRAFT_ORDER_MATERIALIZED
  PROJECT_CONTACT_CREATED
  PROJECT_CONTACT_UPDATED
  PROJECT_FOLDER_CREATED
  PROJECT_FOLDER_RENAMED
  PROJECT_FOLDER_DELETED
  PROJECT_FILE_UPLOADED
  PROJECT_FILE_DELETED
  PROJECT_ESTIMATE_VERSION_CREATED
}

/// Раздел сметы проекта: универсальный (LOCAL), подрядчики (CONTRACTOR) или реквизит по заявке (REQUISITE).
enum ProjectEstimateSectionKind {
  LOCAL
  REQUISITE
  CONTRACTOR
}

enum InventoryAuditRunKind {
  AUTO
  MANUAL
}

enum InventoryAuditSeverity {
  OK
  WARNING
  CRITICAL
  FAILED
}

model User {
  id             String   @id @default(cuid())
  login          String   @unique
  passwordHash   String
  /// Требуется установить личный пароль через flow "Первая авторизация".
  mustSetPassword Boolean @default(false)
  /// Когда пользователь впервые установил личный пароль.
  passwordSetAt   DateTime?
  role           Role
  displayName    String   /// ФИО
  telegramChatId String?  /// ID чата в Telegram для уведомлений
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated   Order[]   @relation("order_created_by")
  ordersGreenwich Order[]   @relation("order_greenwich_user")
  greenwichRating GreenwichRating?
  sessions        Session[]
  achievementProgress AchievementProgress[]
  achievementUnlocks  AchievementUnlock[]
  towerStats          UserTowerStats?
  inAppNotifications  InAppNotification[]
  inventoryAuditRuns  InventoryAuditRun[]
  projectsOwned                 Project[]                   @relation("project_owner")
  projectActivityLogs           ProjectActivityLog[]
  projectCommunicationEntries   ProjectCommunicationEntry[]
  projectFilesUploaded          ProjectFile[]
  projectEstimateVersionsCreated ProjectEstimateVersion[]
  projectDraftOrdersCreated     ProjectDraftOrder[]         @relation("project_draft_order_created_by")
  projectDraftOrdersUpdated     ProjectDraftOrder[]         @relation("project_draft_order_updated_by")

  @@index([role, isActive])
}

/// Текущий рейтинг сотрудника Greenwich (0..100).
model GreenwichRating {
  userId String @id

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  score     Int      @default(100)
  manualLocked Boolean @default(false)
  updatedAt DateTime @updatedAt
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Храним только хеш токена, сырой токен живёт в httpOnly cookie.
  tokenHash String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

/// Idempotency для Telegram-напоминаний (`src/server/reminders/reminder-runner.ts`).
model ReminderSent {
  id             BigInt   @id @default(autoincrement())
  type           String
  orderId        String
  ymd            String
  receiverKey    String
  receiverChatId String
  createdAt      DateTime @default(now())

  @@unique([type, orderId, ymd, receiverKey], map: "ReminderSent_unique")
}

model Customer {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders   Order[]
  projects Project[]

  @@index([isActive, name])
}

/// Проект мероприятия (WOWSTORG): заявки реквизита, смета, контакты — в следующих фазах.
model Project {
  id         String @id @default(cuid())
  title      String
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  ownerUserId String
  owner       User   @relation("project_owner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  status ProjectStatus @default(LEAD)
  ball   ProjectBall   @default(CLIENT)

  /// Не null — проект в архиве (только просмотр в UI, без правок).
  archivedAt DateTime?
  /// Комментарий при переводе в архив (виден в списке архива).
  archiveNote String?

  eventStartDate     DateTime?
  eventEndDate       DateTime?
  eventDateNote      String?
  eventDateConfirmed Boolean   @default(false)
  openBlockers       String?
  internalSummary    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  activityLogs  ProjectActivityLog[]
  contacts      ProjectContact[]
  draftOrders   ProjectDraftOrder[]
  notificationCooldowns ProjectNotificationCooldown[]
  folders       ProjectFolder[]
  projectFiles  ProjectFile[]
  estimateVersions ProjectEstimateVersion[]
  scheduleDays  ProjectScheduleDay[]

  @@index([customerId])
  @@index([ownerUserId])
  @@index([archivedAt])
  @@index([status])
  @@index([updatedAt])
}

/// Append-only журнал событий по проекту (склад).
model ProjectActivityLog {
  id        String @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  actorUserId String
  actor       User   @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  kind    ProjectActivityKind
  payload Json?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([actorUserId])
}

/// ЛПР / контакт по проекту (Wowstorg).
model ProjectContact {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fullName  String
  phone     String?
  email     String?
  category  ProjectContactCategory @default(DECISION_MAKER)
  roleNote  String?
  isActive  Boolean                @default(true)
  sortOrder Int                    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries ProjectCommunicationEntry[]

  @@index([projectId])
  @@index([projectId, isActive])
  @@index([projectId, sortOrder])
}

/// Запись переговоров с контактом (append-only в API).
model ProjectCommunicationEntry {
  id           String         @id @default(cuid())
  contactId    String
  contact      ProjectContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  authorUserId String
  author       User   @relation(fields: [authorUserId], references: [id], onDelete: Restrict)

  body String @db.Text

  createdAt DateTime @default(now())

  @@index([contactId, createdAt])
}

model ProjectNotificationCooldown {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  blockKey  String
  muteUntil DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, blockKey])
  @@index([projectId])
  @@index([projectId, muteUntil])
}

/// Demo/draft-заявка проекта до materialize в реальные заявки склада.
model ProjectDraftOrder {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  estimateVersionId String?
  estimateVersion   ProjectEstimateVersion? @relation(fields: [estimateVersionId], references: [id], onDelete: SetNull)

  title   String?
  comment String?

  createdById String
  createdBy   User   @relation("project_draft_order_created_by", fields: [createdById], references: [id], onDelete: Restrict)

  updatedById String?
  updatedBy   User?  @relation("project_draft_order_updated_by", fields: [updatedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines ProjectDraftOrderLine[]

  @@unique([projectId])
  @@index([projectId])
  @@index([estimateVersionId])
}

model ProjectDraftOrderLine {
  id           String @id @default(cuid())
  draftOrderId String
  draftOrder   ProjectDraftOrder @relation(fields: [draftOrderId], references: [id], onDelete: Cascade)

  sortOrder          Int     @default(0)
  itemId             String
  item               Item    @relation(fields: [itemId], references: [id], onDelete: Restrict)
  itemNameSnapshot   String
  qty                Int
  plannedDays        Int     @default(1)
  comment            String?
  periodGroup        String?
  pricePerDaySnapshot Decimal? @db.Decimal(14, 2)
  lastAvailableQty   Int?
  lastAvailabilityNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([draftOrderId, sortOrder])
  @@index([itemId])
}

/// Папка в файловой зоне проекта (иерархия, корень = parentFolderId null).
model ProjectFolder {
  id             String  @id @default(cuid())
  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentFolderId String?
  parent         ProjectFolder?  @relation("ProjectFolderTree", fields: [parentFolderId], references: [id], onDelete: Restrict)
  children       ProjectFolder[] @relation("ProjectFolderTree")

  name      String
  sortOrder Int     @default(0)
  /// Стартовые «Сметы / Дизайн / Документация» — нельзя удалить (только переименовать).
  isSystem  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  files ProjectFile[]

  @@index([projectId])
  @@index([projectId, parentFolderId])
}

/// Файл в Storage; ключ в бакете не совпадает с id (см. `storageKey`).
model ProjectFile {
  id           String @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  folderId String
  folder   ProjectFolder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  storageKey   String @unique
  originalName String
  mimeType     String
  sizeBytes    Int

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([folderId])
}

/// Версия сметы проекта (конструктор); одна версия может быть явно назначена основной.
model ProjectEstimateVersion {
  id            String  @id @default(cuid())
  projectId     String
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  versionNumber Int
  note          String?
  isPrimary     Boolean @default(false)

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  sections    ProjectEstimateSection[]
  draftOrders ProjectDraftOrder[]

  @@unique([projectId, versionNumber])
  @@index([projectId])
  @@index([projectId, isPrimary])
}

model ProjectEstimateSection {
  id        String @id @default(cuid())
  versionId String
  version   ProjectEstimateVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  sortOrder Int                     @default(0)
  title     String
  kind      ProjectEstimateSectionKind

  /// Для kind = REQUISITE — одна заявка на раздел (блок реквизита).
  linkedOrderId String?
  linkedOrder   Order? @relation(fields: [linkedOrderId], references: [id], onDelete: SetNull)

  /// Локальные поля строк реквизита (ед. изм. и т.п.), ключ = id строки read-model (orderLineId или service key).
  lineLocalExtras Json?

  lines ProjectEstimateLine[]

  @@index([versionId])
  @@index([linkedOrderId])
}

/// Строка сметы (позиция клиента / внутренняя; при копии из заявки — orderLineId).
model ProjectEstimateLine {
  id        String @id @default(cuid())
  sectionId String
  section   ProjectEstimateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  position   Int    @default(0)
  lineNumber Int    @default(0)
  name       String
  description String?
  /// Произвольная метка типа строки (напр. RENTAL, SERVICE).
  lineType      String  @default("OTHER")
  costClient    Decimal? @db.Decimal(14, 2)
  costInternal  Decimal? @db.Decimal(14, 2)

  /// Ед. измерения (пусто/null — в UI подставляется «шт»).
  unit             String?
  qty              Decimal? @db.Decimal(14, 4)
  /// Клиентская цена за единицу (для LOCAL/CONTRACTOR).
  unitPriceClient  Decimal? @db.Decimal(14, 2)

  paymentMethod        String? @db.VarChar(40)
  paymentStatus        String? @db.VarChar(120)
  contractorNote       String? @db.Text
  contractorRequisites String? @db.VarChar(500)

  orderLineId String?
  orderLine   OrderLine? @relation(fields: [orderLineId], references: [id], onDelete: SetNull)

  itemId String?
  item   Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([sectionId, position])
  @@index([orderLineId])
}

/// День тайминга (дата текстом или «День 1»).
model ProjectScheduleDay {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  sortOrder Int    @default(0)
  dateNote  String

  slots ProjectScheduleSlot[]

  @@index([projectId])
}

/// Слот тайминга: интервал + описание сценария.
model ProjectScheduleSlot {
  id          String @id @default(cuid())
  dayId       String
  day         ProjectScheduleDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  sortOrder    Int    @default(0)
  intervalText String
  description  String @db.Text

  @@index([dayId, sortOrder])
}

model Category {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemCategory[]
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        ItemType
  isActive    Boolean  @default(true)

  /// Полная цена/сутки. Для Greenwich применяется коэффициент 0.76 на уровне заказа/сметы.
  pricePerDay Decimal @db.Decimal(12, 2)
  /// Закупочная цена за 1 единицу (опционально, для расчета рентабельности).
  purchasePricePerUnit Decimal? @db.Decimal(12, 2)

  /// Доступные количества учитываются через “ведра”.
  total    Int @default(0)
  inRepair Int @default(0)
  broken   Int @default(0)
  missing  Int @default(0)

  /// Складской “внутренний инвентарь” (скотч/инструмент): не показывать в публичном каталоге.
  internalOnly Boolean @default(false)

  photo1Key String?
  photo2Key String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories  ItemCategory[]
  collections CollectionItem[]
  kitLines    KitLine[]
  orderLines  OrderLine[]
  lossRecords LossRecord[]
  inventoryAuditResults InventoryAuditItemResult[]
  projectEstimateLines ProjectEstimateLine[]
  projectDraftOrderLines ProjectDraftOrderLine[]

  @@index([isActive, internalOnly])
  @@index([name])
}

model Collection {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CollectionItem[]

  @@index([isActive, name])
}

model CollectionItem {
  collectionId String
  itemId       String
  position     Int @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([collectionId, itemId])
  @@index([itemId])
  @@index([collectionId, position])
}

model ItemCategory {
  itemId     String
  categoryId String

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
  @@index([categoryId])
}

model Kit {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines      KitLine[]
  orderLines OrderLine[]
}

model KitLine {
  id         String @id @default(cuid())
  kitId      String
  itemId     String
  defaultQty Int

  kit  Kit  @relation(fields: [kitId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([kitId, itemId])
  @@index([kitId])
}

model Order {
  id     String      @id @default(cuid())
  source OrderSource
  status OrderStatus @default(SUBMITTED)

  createdById String
  createdBy   User   @relation("order_created_by", fields: [createdById], references: [id], onDelete: Restrict)

  /// Для заявок “для Greenwich” (создал ли Greenwich сам, или склад создал за него).
  greenwichUserId String?
  greenwichUser   User?   @relation("order_greenwich_user", fields: [greenwichUserId], references: [id], onDelete: Restrict)

  /// Быстрая доп.-выдача (Quick Supplement): если заполнено, заявка является “дополнением” к parentOrder.
  /// Считаем признаком quick доп.-выдачи `parentOrderId != null`.
  parentOrderId String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  eventName String?
  comment   String?

  /// date-only (в коде нормализуем к полуночи и валидируем формат)
  readyByDate DateTime
  startDate   DateTime
  endDate     DateTime

  deliveryEnabled  Boolean  @default(false)
  deliveryComment  String?
  deliveryPrice    Decimal? @db.Decimal(12, 2)
  montageEnabled   Boolean  @default(false)
  montageComment   String?
  montagePrice     Decimal? @db.Decimal(12, 2)
  demontageEnabled Boolean  @default(false)
  demontageComment String?
  demontagePrice   Decimal? @db.Decimal(12, 2)

  /// Наша себестоимость доп. услуг (для маржи в смете проекта; клиентские суммы — deliveryPrice / montagePrice / demontagePrice).
  deliveryInternalCost  Decimal? @db.Decimal(12, 2)
  montageInternalCost   Decimal? @db.Decimal(12, 2)
  demontageInternalCost Decimal? @db.Decimal(12, 2)

  /// Для Greenwich фиксированный коэффициент 0.76, но сохраняем на заказ,
  /// чтобы изменения правил не ломали историю.
  payMultiplier Decimal @db.Decimal(5, 4)

  /// Ручная скидка склада на аренду реквизита (не применяется к доп. услугам).
  rentalDiscountType    OrderDiscountType @default(NONE)
  rentalDiscountPercent Decimal?          @db.Decimal(5, 2)
  rentalDiscountAmount  Decimal?          @db.Decimal(12, 2)

  /// Запрос скидки от Greenwich. Не влияет на расчёты до подтверждения складом.
  greenwichRequestedDiscountType    OrderDiscountType @default(NONE)
  greenwichRequestedDiscountPercent Decimal?          @db.Decimal(5, 2)
  greenwichRequestedDiscountAmount  Decimal?          @db.Decimal(12, 2)
  greenwichDiscountRequestComment   String?

  estimateSentAt       DateTime?
  estimateSentSnapshot Json?
  estimateFileKey      String?

  /// Снэпшот заявки в момент «Запрошены изменения» (без цен доп. услуг) — для сравнения при отправке сметы.
  changesRequestedSnapshot Json?

  greenwichConfirmedAt       DateTime?
  greenwichConfirmedSnapshot Json?

  /// Внутренняя заметка склада (только для сотрудников склада, не для клиента).
  warehouseInternalNote String?

  /// Компонент просрочки для рейтинга Greenwich.
  /// Считается на `return-declared` (когда Greenwich отправил возврат на приёмку).
  greenwichRatingOverdueDelta Int @default(0)

  /// Компонент инцидентов для рейтинга Greenwich.
  /// Считается на `check-in` (когда склад подтвердил фактические статусы возврата).
  greenwichRatingIncidentsDelta Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines        OrderLine[]
  returnSplits ReturnSplit[]
  incidents    Incident[]
  lossRecords  LossRecord[]
  projectEstimateSections ProjectEstimateSection[]

  @@index([status, readyByDate])
  @@index([source, status])
  @@index([customerId])
  @@index([greenwichUserId])
  @@index([parentOrderId])
  @@index([projectId])
}

model OrderLine {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  /// Если строка пришла из кита — сохраняем источник, чтобы в смете/диффах можно было группировать.
  sourceKitId String?
  sourceKit   Kit?    @relation(fields: [sourceKitId], references: [id], onDelete: SetNull)

  requestedQty Int
  approvedQty  Int?
  issuedQty    Int?

  /// Снэпшот цены на момент формирования строки/сметы
  pricePerDaySnapshot Decimal @db.Decimal(12, 2)

  /// Комментарии
  greenwichComment String?
  warehouseComment String?

  position Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  returnSplits ReturnSplit[]
  incidents    Incident[]
  lossRecords  LossRecord[]
  projectEstimateLines ProjectEstimateLine[]

  @@index([orderId, position])
  @@index([itemId])
}

/// Разбиение количества по состояниям для возврата/приёмки.
/// Используется и для декларации Greenwich, и для факта склада.
model ReturnSplit {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  phase     ReturnPhase
  condition Condition
  qty       Int
  comment   String?

  createdAt DateTime @default(now())

  @@index([orderId, phase])
  @@index([orderLineId, phase])
}

model Incident {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  condition Condition
  qty       Int
  repairedQty Int @default(0)
  utilizedQty Int @default(0)
  status IncidentStatus @default(OPEN)
  comment   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resolvedAt DateTime?

  @@index([status, condition])
}

/// Учёт недостач с жизненным циклом “найдено/списано”.
model LossRecord {
  id     String     @id @default(cuid())
  status LossStatus @default(OPEN)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  orderLineId String?
  orderLine   OrderLine? @relation(fields: [orderLineId], references: [id], onDelete: SetNull)

  qty   Int
  foundQty Int @default(0)
  writtenOffQty Int @default(0)
  notes String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([itemId, status])
}

model AchievementProgress {
  id    String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code  AchievementCode
  value Int @default(0)
  level AchievementLevel @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, code])
  @@index([userId, level])
}

model AchievementUnlock {
  id    String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code       AchievementCode
  level      AchievementLevel
  unlockedAt DateTime @default(now())

  @@unique([userId, code, level])
  @@index([userId, unlockedAt])
}

model UserTowerStats {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bestScore Int @default(0)
  lastScore Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InAppNotification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type InAppNotificationType
  title String
  body  String
  payloadJson Json?
  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

model InventoryAuditRun {
  id        String @id @default(cuid())
  kind      InventoryAuditRunKind
  severity  InventoryAuditSeverity
  startedAt DateTime @default(now())
  finishedAt DateTime?
  summaryJson Json?
  errorText String?

  createdByUserId String?
  createdByUser   User? @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  itemResults InventoryAuditItemResult[]

  @@index([startedAt])
  @@index([severity, startedAt])
}

model InventoryAuditItemResult {
  id      String @id @default(cuid())
  runId   String
  run     InventoryAuditRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  itemId  String
  item    Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  severity InventoryAuditSeverity
  expectedJson Json
  actualJson   Json
  deltaJson    Json
  explanationJson Json?

  @@index([runId, severity])
  @@index([itemId])
}
