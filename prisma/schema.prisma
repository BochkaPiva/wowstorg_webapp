generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GREENWICH
  WOWSTORG
}

enum ItemType {
  ASSET
  BULK
  CONSUMABLE
}

enum OrderSource {
  GREENWICH_INTERNAL
  WOWSTORG_EXTERNAL
}

enum OrderStatus {
  SUBMITTED
  ESTIMATE_SENT
  CHANGES_REQUESTED
  APPROVED_BY_GREENWICH
  PICKING
  ISSUED
  RETURN_DECLARED
  CLOSED
  CANCELLED
}

enum Condition {
  OK
  NEEDS_REPAIR
  BROKEN
  MISSING
}

enum ReturnPhase {
  DECLARED
  CHECKED_IN
}

enum LossStatus {
  OPEN
  FOUND
  WRITTEN_OFF
}

enum IncidentStatus {
  OPEN
  CLOSED
}

enum AchievementCode {
  PERFECT_ORDERS
  TOWER_SCORE
  ORDER_VOLUME
  BIGGEST_CHECK
  CLOSED_ORDERS
  NO_CANCEL_STREAK
}

enum AchievementLevel {
  NONE
  BRONZE
  SILVER
  GOLD
}

enum InAppNotificationType {
  ACHIEVEMENT_UNLOCK
}

model User {
  id             String   @id @default(cuid())
  login          String   @unique
  passwordHash   String
  role           Role
  displayName    String   /// ФИО
  telegramChatId String?  /// ID чата в Telegram для уведомлений
  isActive       Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated   Order[]   @relation("order_created_by")
  ordersGreenwich Order[]   @relation("order_greenwich_user")
  greenwichRating GreenwichRating?
  sessions        Session[]
  achievementProgress AchievementProgress[]
  achievementUnlocks  AchievementUnlock[]
  towerStats          UserTowerStats?
  inAppNotifications  InAppNotification[]

  @@index([role, isActive])
}

/// Текущий рейтинг сотрудника Greenwich (0..100).
model GreenwichRating {
  userId String @id

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  score     Int      @default(100)
  manualLocked Boolean @default(false)
  updatedAt DateTime @updatedAt
}

model Session {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Храним только хеш токена, сырой токен живёт в httpOnly cookie.
  tokenHash String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Customer {
  id       String  @id @default(cuid())
  name     String
  isActive Boolean @default(true)
  notes    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([isActive, name])
}

model Category {
  id    String @id @default(cuid())
  name  String
  slug  String @unique
  order Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ItemCategory[]
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        ItemType
  isActive    Boolean  @default(true)

  /// Полная цена/сутки. Для Greenwich применяется коэффициент 0.76 на уровне заказа/сметы.
  pricePerDay Decimal @db.Decimal(12, 2)
  /// Закупочная цена за 1 единицу (опционально, для расчета рентабельности).
  purchasePricePerUnit Decimal? @db.Decimal(12, 2)

  /// Доступные количества учитываются через “ведра”.
  total    Int @default(0)
  inRepair Int @default(0)
  broken   Int @default(0)
  missing  Int @default(0)

  /// Складской “внутренний инвентарь” (скотч/инструмент): не показывать в публичном каталоге.
  internalOnly Boolean @default(false)

  photo1Key String?
  photo2Key String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories  ItemCategory[]
  collections CollectionItem[]
  kitLines    KitLine[]
  orderLines  OrderLine[]
  lossRecords LossRecord[]

  @@index([isActive, internalOnly])
  @@index([name])
}

model Collection {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items CollectionItem[]

  @@index([isActive, name])
}

model CollectionItem {
  collectionId String
  itemId       String
  position     Int @default(0)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  item       Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@id([collectionId, itemId])
  @@index([itemId])
  @@index([collectionId, position])
}

model ItemCategory {
  itemId     String
  categoryId String

  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([itemId, categoryId])
  @@index([categoryId])
}

model Kit {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines      KitLine[]
  orderLines OrderLine[]
}

model KitLine {
  id         String @id @default(cuid())
  kitId      String
  itemId     String
  defaultQty Int

  kit  Kit  @relation(fields: [kitId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([kitId, itemId])
  @@index([kitId])
}

model Order {
  id     String      @id @default(cuid())
  source OrderSource
  status OrderStatus @default(SUBMITTED)

  createdById String
  createdBy   User   @relation("order_created_by", fields: [createdById], references: [id], onDelete: Restrict)

  /// Для заявок “для Greenwich” (создал ли Greenwich сам, или склад создал за него).
  greenwichUserId String?
  greenwichUser   User?   @relation("order_greenwich_user", fields: [greenwichUserId], references: [id], onDelete: Restrict)

  /// Быстрая доп.-выдача (Quick Supplement): если заполнено, заявка является “дополнением” к parentOrder.
  /// Считаем признаком quick доп.-выдачи `parentOrderId != null`.
  parentOrderId String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  eventName String?
  comment   String?

  /// date-only (в коде нормализуем к полуночи и валидируем формат)
  readyByDate DateTime
  startDate   DateTime
  endDate     DateTime

  deliveryEnabled  Boolean  @default(false)
  deliveryComment  String?
  deliveryPrice    Decimal? @db.Decimal(12, 2)
  montageEnabled   Boolean  @default(false)
  montageComment   String?
  montagePrice     Decimal? @db.Decimal(12, 2)
  demontageEnabled Boolean  @default(false)
  demontageComment String?
  demontagePrice   Decimal? @db.Decimal(12, 2)

  /// Для Greenwich фиксированный коэффициент 0.76, но сохраняем на заказ,
  /// чтобы изменения правил не ломали историю.
  payMultiplier Decimal @db.Decimal(5, 4)

  estimateSentAt       DateTime?
  estimateSentSnapshot Json?
  estimateFileKey      String?

  /// Снэпшот заявки в момент «Запрошены изменения» (без цен доп. услуг) — для сравнения при отправке сметы.
  changesRequestedSnapshot Json?

  greenwichConfirmedAt       DateTime?
  greenwichConfirmedSnapshot Json?

  /// Внутренняя заметка склада (только для сотрудников склада, не для клиента).
  warehouseInternalNote String?

  /// Компонент просрочки для рейтинга Greenwich.
  /// Считается на `return-declared` (когда Greenwich отправил возврат на приёмку).
  greenwichRatingOverdueDelta Int @default(0)

  /// Компонент инцидентов для рейтинга Greenwich.
  /// Считается на `check-in` (когда склад подтвердил фактические статусы возврата).
  greenwichRatingIncidentsDelta Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lines        OrderLine[]
  returnSplits ReturnSplit[]
  incidents    Incident[]
  lossRecords  LossRecord[]

  @@index([status, readyByDate])
  @@index([source, status])
  @@index([customerId])
  @@index([greenwichUserId])
  @@index([parentOrderId])
}

model OrderLine {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  /// Если строка пришла из кита — сохраняем источник, чтобы в смете/диффах можно было группировать.
  sourceKitId String?
  sourceKit   Kit?    @relation(fields: [sourceKitId], references: [id], onDelete: SetNull)

  requestedQty Int
  approvedQty  Int?
  issuedQty    Int?

  /// Снэпшот цены на момент формирования строки/сметы
  pricePerDaySnapshot Decimal @db.Decimal(12, 2)

  /// Комментарии
  greenwichComment String?
  warehouseComment String?

  position Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  returnSplits ReturnSplit[]
  incidents    Incident[]
  lossRecords  LossRecord[]

  @@index([orderId, position])
  @@index([itemId])
}

/// Разбиение количества по состояниям для возврата/приёмки.
/// Используется и для декларации Greenwich, и для факта склада.
model ReturnSplit {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  phase     ReturnPhase
  condition Condition
  qty       Int
  comment   String?

  createdAt DateTime @default(now())

  @@index([orderId, phase])
  @@index([orderLineId, phase])
}

model Incident {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  orderLineId String
  orderLine   OrderLine @relation(fields: [orderLineId], references: [id], onDelete: Cascade)

  condition Condition
  qty       Int
  repairedQty Int @default(0)
  utilizedQty Int @default(0)
  status IncidentStatus @default(OPEN)
  comment   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resolvedAt DateTime?

  @@index([status, condition])
}

/// Учёт недостач с жизненным циклом “найдено/списано”.
model LossRecord {
  id     String     @id @default(cuid())
  status LossStatus @default(OPEN)

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Restrict)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: SetNull)

  orderLineId String?
  orderLine   OrderLine? @relation(fields: [orderLineId], references: [id], onDelete: SetNull)

  qty   Int
  foundQty Int @default(0)
  writtenOffQty Int @default(0)
  notes String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([itemId, status])
}

model AchievementProgress {
  id    String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code  AchievementCode
  value Int @default(0)
  level AchievementLevel @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, code])
  @@index([userId, level])
}

model AchievementUnlock {
  id    String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  code       AchievementCode
  level      AchievementLevel
  unlockedAt DateTime @default(now())

  @@unique([userId, code, level])
  @@index([userId, unlockedAt])
}

model UserTowerStats {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  bestScore Int @default(0)
  lastScore Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InAppNotification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type InAppNotificationType
  title String
  body  String
  payloadJson Json?
  isRead Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}
